# Copy this file to .env and fill in real values.
# Both backend (FastAPI) and frontend (Next.js) read from their own .env files;
# this root .env.example documents the full set required across the stack.

# ---- Upstage (Solar Pro, Document Parse, Embedding, Groundedness Check) ----
# Get from: https://console.upstage.ai -> API Keys
UPSTAGE_API_KEY=up_REPLACE_ME

# ---- Supabase (Postgres + Auth + Storage; replaces local SQLite) ----
# Use the *new* key system:
#   - Publishable key = browser-safe (replaces legacy "anon").
#   - Secret key      = server-only, bypasses RLS (replaces legacy "service_role").
# Get from: Supabase Dashboard -> Project Settings -> API Keys
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
# Server-side only. Has full DB privileges. NEVER expose to the frontend.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

# ---- Backend ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of frontend origins allowed by CORS.
CORS_ALLOW_ORIGINS=http://localhost:3000

# ---- Frontend (Next.js) ----
# Public URL of the FastAPI backend, callable from the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
# Public Supabase config used from the browser (publishable key only — never secret).
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_ME.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# ---- LLM tuning (optional) ----
SOLAR_MODEL=solar-pro2
SOLAR_TEMPERATURE=0.2
GROUNDEDNESS_THRESHOLD=0.7

# ---- 국가법령정보센터 Open API (optional) ----
# Enables GET /law/term for legal-term lookup. Without this key the endpoint
# returns 503 but the rest of the service (rewrite, glossary, history) works.
# Get from: https://open.law.go.kr -> OPEN API -> API 신청 (OC key)
LAW_API_KEY=
