# 사용할 LLM 선택: gemini | groq | ollama
LLM_PROVIDER=groq

# Gemini API 키 (https://aistudio.google.com/app/apikey 에서 무료 발급)
GEMINI_API_KEY=your-gemini-api-key-here

# Groq API 키 (https://console.groq.com 에서 무료 발급)
GROQ_API_KEY=your-groq-api-key-here

# 법령 API 키 (https://www.law.go.kr/DRF 에서 발급)
LAW_API_KEY=your-law-api-key-here

# Ollama 로컬 모델명 (ollama pull gemma2:9b 로 다운로드)
# OLLAMA_MODEL=gemma2:9b
