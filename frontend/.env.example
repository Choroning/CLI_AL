# Frontend-only env. Copy to frontend/.env.local.
# NEXT_PUBLIC_* values are exposed to the browser.

# Local dev:    http://localhost:8000
# Public (via cloudflared crn-service): https://apic.choroning.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Browser-side Supabase config. Use only the publishable key (formerly "anon").
# NEVER put the secret key here.
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_ME.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
