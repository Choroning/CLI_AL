# Backend-only env. Copy to backend/.env.

UPSTAGE_API_KEY=up_REPLACE_ME

SUPABASE_URL=https://REPLACE_ME.supabase.co
# Server-side secret key (formerly "service_role"). Bypasses RLS. NEVER expose to FE.
SUPABASE_SECRET_KEY=sb_secret_REPLACE_ME

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of allowed frontend origins. Production value lives in
# the Render dashboard (https://cli-al.vercel.app); this is a local-dev default.
CORS_ALLOW_ORIGINS=http://localhost:3000

# Solar model id. Verify the latest available in Upstage Console.
# Common values seen so far: "solar-pro2", "solar-pro", "solar-mini".
SOLAR_MODEL=solar-pro2
SOLAR_TEMPERATURE=0.2
GROUNDEDNESS_THRESHOLD=0.7

# 국가법령정보센터 Open API (https://www.law.go.kr/LSW/openApi.do)
# OC 키 발급 후 입력. 없으면 /law/term 엔드포인트가 503을 반환.
LAW_API_KEY=your_oc_key_here
